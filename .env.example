# Copy this file to .env and fill in your actual values.
#
# Any variable consumed by the React app (src/) must be prefixed with
# REACT_APP_ so create-react-app exposes it to the client bundle.
# Unprefixed vars here are consumed only by admin scripts in scripts/
# and any ad-hoc backend entry points.

# api.video key used by src/components/media/VideoUploader.jsx to mint
# delegated upload tokens client-side. See the file header for security
# caveats — this value is bundled into the browser JS on build.
REACT_APP_API_VIDEO_KEY=your_api_video_key_here
