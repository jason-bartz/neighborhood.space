rules_version = '2';
  service cloud.firestore {
    match /databases/{database}/documents {

      // --- Helpers ---
      function getUserData(userId) {
        return get(/databases/$(database)/documents/users/$(userId)).data;
      }
      function requestUserData() {
        return request.auth != null ? getUserData(request.auth.uid) : null;
      }
      function hasRole(roles) {
        let userData = requestUserData();
        return userData != null && userData.role != null && (
          (userData.role == 'lp' && 'lp' in roles) ||
          (userData.role == 'chapter_director' && 'chapter_director' in roles) ||
          (userData.role == 'superAdmin' && 'superAdmin' in roles)
        );
      }
      // Any authenticated user with a portal role. Tier summary:
      //   superAdmin       — global write access, only tier that can touch
      //                      other superAdmin records or run migrations.
      //   chapter_director — chapter-scoped management. Owns user/chapter
      //                      writes for users in their chapter; scoping is
      //                      enforced in /users update via chapterDirectorOwnsTarget()
      //                      and in /chapters update via the name-match check.
      //   lp               — standard reviewer tier. Read-mostly: can list/read
      //                      users and chapters, can write reviews and bulletin
      //                      messages, but cannot mutate other users' profiles.
      function isValidUser() {
        return hasRole(['lp', 'chapter_director', 'superAdmin']);
      }
      // Retained as an alias used throughout the rules. After the chapter-scope
      // tightening on /users.update, this no longer implies "can update any user"
      // — it just means "has elevated read/list access at this call site".
      function isAdminOrSuperAdmin() {
        return hasRole(['lp', 'chapter_director', 'superAdmin']);
      }
      function isChapterDirector() {
        return hasRole(['chapter_director']);
      }
      function isSuperAdmin() {
        return hasRole(['superAdmin']);
      }
      // True when the caller is a chapter_director acting on a user that
      // belongs to their chapter — either the target already lives in that
      // chapter (read existing /users/{uid}.chapter from `resource.data`) or
      // the write is moving them INTO that chapter (read the incoming value
      // from `request.resource.data.chapter`). The OR-on-incoming preserves
      // first-time chapter assignment when promoting a brand-new portal user.
      function chapterDirectorOwnsTarget() {
        let userData = requestUserData();
        return userData != null
               && userData.role == 'chapter_director'
               && userData.chapter != null
               && (resource.data.chapter == userData.chapter
                   || request.resource.data.chapter == userData.chapter);
      }

      // --- USERS COLLECTION ---
      match /users/{userId} {
        // Public get: any LP / chapter_director profile (for the public chapter
        // landing pages). Name, role, bio, linkedinUrl, photoUrl are already
        // designed to be shown publicly on the chapter page — no sensitive
        // fields beyond standard contact info live on these docs. Client-side
        // code filters out active:false profiles before rendering.
        allow get: if request.auth.uid == userId
                   || (isValidUser() && requestUserData().chapter == resource.data.chapter)
                   || isAdminOrSuperAdmin()
                   || resource.data.role in ['lp', 'chapter_director']
                   // SuperAdmins with a chapterRole set are publicly listed on
                   // their chapter page in that role. The role field still drives
                   // capability; chapterRole only drives presentation.
                   || (resource.data.role == 'superAdmin'
                       && resource.data.chapterRole in ['lp', 'chapter_director']);

        // List is document-scoped under Firestore v2: every doc the query
        // returns must pass the rule. So if the client adds
        //   .where('role', 'in', ['lp','chapter_director'])
        // every returned doc's role will match the public read clause below
        // and unauthenticated visitors get the chapter's LP directory.
        allow list: if (isValidUser() && request.auth != null)
                    || isAdminOrSuperAdmin()
                    || resource.data.role in ['lp', 'chapter_director']
                    || (resource.data.role == 'superAdmin'
                        && resource.data.chapterRole in ['lp', 'chapter_director']);

        allow delete: if isAdminOrSuperAdmin() && request.auth.uid != userId;

        // chapterRole is a display-only field that pins a superAdmin to a
        // chapter's public roster in a secondary role (lp / chapter_director).
        // It is meaningless — and so forbidden — on any other role. This
        // invariant is enforced on every create and update; the AND below
        // means no permission branch can bypass it.
        function chapterRoleInvariant() {
          return !('chapterRole' in request.resource.data)
                 || request.resource.data.chapterRole == null
                 || (request.resource.data.role == 'superAdmin'
                     && request.resource.data.chapterRole in ['lp', 'chapter_director']);
        }

        allow create: if (request.auth.uid == userId || isAdminOrSuperAdmin())
                      && chapterRoleInvariant();
        // Update tiers, in increasing privilege:
        //   1. Self-edit: anyone can edit their own profile fields (name, bio,
        //      links, photo). Role/chapter changes are blocked here.
        //   2. LP: standard reviewer tier — read-mostly. Cannot mutate other
        //      users' records (legacy global-update access removed; chapter
        //      management is the chapter_director / superAdmin job).
        //   3. Chapter director: full update on users in their own chapter
        //      (or being promoted into it), provided neither the existing nor
        //      the incoming role is superAdmin.
        //   4. SuperAdmin: unrestricted.
        allow update: if (
          (request.auth.uid == userId &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['name', 'linkedinUrl', 'professionalRole', 'bio', 'photoUrl']))
          || (chapterDirectorOwnsTarget() &&
              resource.data.role != 'superAdmin' &&
              request.resource.data.role != 'superAdmin')
          || isSuperAdmin()
        ) && chapterRoleInvariant();
      }

      // --- PITCHES COLLECTION ---
      match /pitches/{pitchId} {
        // Allow anyone to read pitches (needed for public voting on showcase)
        // Cloud Functions automatically have full access - no rule changes needed for them
        allow read: if true;

        // Allow anyone to create a pitch (needed for the submission form)
        // This enables your form to work without authentication
        allow create: if true;

        // Allow anyone to update vote count only (for email-based voting)
        // OR allow admins to update any fields
        allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes'])
                         && request.resource.data.votes == resource.data.votes + 1)
                      || isAdminOrSuperAdmin();

        // Only admins can delete pitches
        allow delete: if isAdminOrSuperAdmin();
      }

      // --- LP APPLICATIONS COLLECTION ---
      match /lpApplications/{lpId} {
        // Anyone can submit an LP application (public form, no auth)
        allow create: if true;

        // Only admins can read, update, or delete LP applications
        allow read: if isAdminOrSuperAdmin();
        allow update: if isAdminOrSuperAdmin();
        allow delete: if isAdminOrSuperAdmin();
      }

      // --- REVIEWS COLLECTION ---
      match /reviews/{reviewId} {
        function isOwner() {
          return request.auth.uid != null
                 && request.auth.uid == reviewId.split('_')[0];
        }
        // Owners can read their own review, admins can read any
        allow get: if isOwner() || isAdminOrSuperAdmin();
        // Admins can list all; LPs can list reviews in their chapter (for shared team notes)
        allow list: if isAdminOrSuperAdmin()
                    || (isValidUser() && resource.data.chapter == requestUserData().chapter);
        // Allow valid users (lp, admin, superAdmin) to write if reviewerId matches
        allow write: if isValidUser()
                     && request.auth.uid != null
                     && (request.resource.data.reviewerId == request.auth.uid
                         || isAdminOrSuperAdmin());
        allow delete: if isOwner() || isAdminOrSuperAdmin();
      }

      // --- INVITATIONS COLLECTION ---
      match /invitations/{inviteId} {
        allow read, write: if isAdminOrSuperAdmin();
      }

      // --- GUEST MESSAGES COLLECTION ---
      match /guestMessages/{msgId} {
        allow create: if true;  // Anyone can leave a message
        allow read: if true;    // Messages are publicly visible
        allow update, delete: if isAdminOrSuperAdmin();  // Only admins can edit/delete
      }

      // --- BULLETIN POSTS COLLECTION ---
      match /bulletinPosts/{postId} {
        // Only valid users (lp, admin, superAdmin) can read bulletin posts
        allow read: if isValidUser();

        // Valid users can create posts
        allow create: if isValidUser()
                      && request.resource.data.author.uid == request.auth.uid;

        // Users can update their own posts, admins can update any post
        allow update: if isValidUser()
                      && (resource.data.author.uid == request.auth.uid
                          || isAdminOrSuperAdmin());

        // Users can delete their own posts, admins can delete any post
        allow delete: if isValidUser()
                      && (resource.data.author.uid == request.auth.uid
                          || isAdminOrSuperAdmin());
      }

      // --- BULLETIN MESSAGES COLLECTION (Chapter-specific) ---
      match /bulletinMessages/{messageId} {
        // Valid users can read messages from their own chapter only
        allow read: if isValidUser()
                    && requestUserData().chapter == resource.data.authorChapter;

        // Valid users can create messages for their chapter
        allow create: if isValidUser()
                      && request.auth.uid == request.resource.data.authorId
                      && request.resource.data.authorChapter == requestUserData().chapter;

        // Users can update their own messages, admins can update any in their chapter
        allow update: if isValidUser() && (
          request.auth.uid == resource.data.authorId ||
          (isAdminOrSuperAdmin() &&
           resource.data.authorChapter == requestUserData().chapter)
        );

        // Users can delete their own messages, admins can delete any in their chapter  
        allow delete: if isValidUser() && (
          request.auth.uid == resource.data.authorId ||
          (isAdminOrSuperAdmin() &&
           resource.data.authorChapter == requestUserData().chapter)
        );
      }

      // --- LIMITED PARTNERS COLLECTION ---
      // Note: This collection might be deprecated in favor of the users collection with roles
      match /limitedPartners/{lpId} {
        // Only admins can read/write to limited partners collection
        allow read: if isAdminOrSuperAdmin();
        allow write: if isAdminOrSuperAdmin();
      }

      // --- CHAPTERS COLLECTION ---
      // Chapter metadata + landing-page content (hero text, serving section,
      // counties list, toggles for optional sections). Public read so the
      // static /<slug>.html pages can hydrate live content and application
      // forms can populate chapter dropdowns.
      //
      // Create/delete: superAdmin only.
      // Update: superAdmin (any field) OR chapter_director (their own chapter,
      //         restricted to the editable content fields below).
      match /chapters/{chapterId} {
        // Fields a chapter director is allowed to write through the portal
        // form. Anything else (slug, pageSlug, emailAlias, Slack IDs, order,
        // active, createdAt, createdBy, name) is locked down to superAdmin.
        function directorEditableFields() {
          return [
            'heroTitle', 'heroTagline',
            'servingTitle', 'servingText', 'counties',
            'poweredByText',
            'showLPs', 'showGallery',
            // Hero image + caption shown in the chapter-page hero block.
            // heroImageStoragePath lets the uploader delete the previous file
            // when a new one is uploaded. Storage lives under chapter-photos/{slug}/.
            'heroImage', 'heroImageCaption', 'heroImageStoragePath',
            // Community gallery photos — array of { url, storagePath, caption? }.
            'galleryPhotos',
            // Map of {userId: {name, photoUrl}} mirrored from /users when a
            // chapter director uploads a member photo. Public reads (the
            // /chapters doc is world-readable) feed the static landing pages.
            'lpPhotos',
            'updatedAt'
          ];
        }

        allow read: if true;
        allow create, delete: if isSuperAdmin();
        allow update: if isSuperAdmin()
                      || (isChapterDirector()
                          && resource.data.name == requestUserData().chapter
                          && request.resource.data.diff(resource.data)
                             .affectedKeys().hasOnly(directorEditableFields()));
      }

      // --- RESOURCES COLLECTION ---
      match /resources/{resourceId} {
        // Anyone can read resources (public information)
        allow read: if true;

        // Only admins can create/update/delete resources
        allow write: if isAdminOrSuperAdmin();
      }

      // --- VOTES COLLECTION ---
      match /votes/{voteId} {
        // Anyone can read votes (for transparency)
        allow read: if true;
        
        // Allow anyone to create votes with email
        // Email duplicate checking is done in the frontend
        allow create: if request.resource.data.keys().hasAll(['email', 'pitchId', 'timestamp', 'contest'])
                      && request.resource.data.email is string
                      && request.resource.data.email.matches('.*@.*');
        
        // No updates or deletes allowed to maintain vote integrity
        allow update: if false;
        allow delete: if false;
      }

      // --- NEWSLETTER COLLECTION ---
      match /newsletter/{email} {
        // Allow public reads for admin purposes
        allow read: if isAdminOrSuperAdmin();
        
        // Allow anyone to subscribe (public form)
        allow create: if request.resource.data.keys().hasAll(['email', 'source', 'timestamp', 'subscribed'])
                      && request.resource.data.subscribed == true;
        
        // Allow users to update their own subscription status
        allow update: if request.resource.data.email == resource.data.email
                      && request.resource.data.keys().hasAll(['email', 'source', 'timestamp', 'subscribed']);
        
        // Only admins can delete
        allow delete: if isAdminOrSuperAdmin();
      }

    }
  }